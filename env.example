# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────
 
MT5_ACCOUNT=12345678
 
MT5_PASSWORD=your_password_here
 
MT5_SERVER=Exness-MT5Trial9

# Comma-separated list of symbols (exact names from MT5 Market Watch)
# Exness standard demo accounts use the 'm' suffix
MT5_SYMBOLS=EURUSDm,XAUUSDm

# Optional overrides (safe to leave as defaults)
MT5_POLL_INTERVAL_MS=100
MT5_EXEC_POLL_INTERVAL_MS=250
MT5_MAGIC_NUMBER=510
